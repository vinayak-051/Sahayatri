VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Web Push public key — generate with `npx web-push generate-vapid-keys`.
# Without this, the app still works but push notifications are skipped.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Sentry error monitoring (optional) — create a free project at sentry.io and
# paste its DSN here. Without this, error reporting is skipped entirely.
VITE_SENTRY_DSN=
VITE_ADMIN_EMAIL=your-admin-email@example.com
